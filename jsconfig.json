{
    "compilerOptions": {
        "strict": true,
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "target": "ESNext",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "pretty": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "types": ["bun-types", "node"]
    },
    "include": ["src/**/*", "test/**/*", "types"]
}